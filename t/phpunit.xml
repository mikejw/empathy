<?xml version="1.0" encoding="utf-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" bootstrap="bootstrap.php" backupGlobals="false" stopOnFailure="false" verbose="true" colors="true" xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.3/phpunit.xsd">
  <coverage processUncoveredFiles="false">
    <include>
      <directory suffix=".php">../src/</directory>
      <directory suffix=".php">../eaa/</directory>
    </include>
    <report>
      <html outputDirectory="../build/coverage" lowUpperBound="35" highLowerBound="70"/>
    </report>
  </coverage>
  <testsuites>
    <testsuite name="MVC">
      <directory suffix="Test.php">./ESuite/MVC</directory>
    </testsuite>
  </testsuites>
  <logging>
    <junit outputFile="../build/testsuite.xml"/>
  </logging>
</phpunit>
