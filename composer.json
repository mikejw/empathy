{
  "name": "mikejw/empathy",
  "type": "library",
  "description": "Empathy MVC",
  "keywords": [
    "framework",
    "mvc"
  ],
  "homepage": "https://empathy.sh",
  "license": "MIT",
  "authors": [
    {
      "name": "Michael J. Whiting",
      "email": "mail@mikejw.co.uk"
    }
  ],
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/mikejw/alice"
    }
  ],
  "require": {
    "php": ">=8.4.0",
    "wp-cli/php-cli-tools": "dev-main",
    "mustangostang/spyc": "0.6.3",
    "mikejw/elibs": "^2",
    "php-di/php-di": "^7.0",
    "monolog/monolog": "^2.5.0",
    "ext-pdo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "squizlabs/php_codesniffer": "^3.7.2",
    "mockery/mockery": "^1.3.0",
    "nelmio/alice": "dev-2.x-dev",
    "laravel/pint": "^1.29",
    "phpstan/phpstan": "^2.1",
    "rector/rector": "^2.3",
    "pestphp/pest": "^4.4"
  },
  "autoload": {
    "psr-0": {
      "Empathy\\": "src/"
    },
    "classmap": [
      "src/R.php"
    ]
  },
  "autoload-dev": {
    "psr-0": {
      "Esuite\\": "t/"
    },
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/empathy"
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "format": "pint ./src ./t ./tests",
    "format-check": "pint --test ./src ./t ./tests",
    "analyse": "phpstan --memory-limit=1G",
    "test": "pest",
    "test:phpunit": "phpunit -c ./t/phpunit.xml",
    "test:coverage": "XDEBUG_MODE=coverage pest --coverage-html ./build/coverage",
    "check": [
      "@format-check",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
