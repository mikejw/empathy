{
  "name": "mikejw/empathy",
  "type": "library",
  "description": "Empathy MVC",
  "keywords": [
    "framework",
    "mvc"
  ],
  "homepage": "https://empathy.sh",
  "license": "MIT",
  "authors": [
    {
      "name": "Michael J. Whiting",
      "email": "mail@mikejw.co.uk"
    }
  ],
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/mikejw/alice"
    }
  ],
  "require": {
    "php": ">=8.4.0",
    "wp-cli/php-cli-tools": "dev-main",
    "mustangostang/spyc": "0.6.3",
    "mikejw/elibs": "^2",
    "php-di/php-di": "^7.0",
    "monolog/monolog": "^2.5.0",
    "ext-pdo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9",
    "squizlabs/php_codesniffer": "^3.7.2",
    "mockery/mockery": "^1.3.0",
    "nelmio/alice": "dev-2.x-dev",
    "laravel/pint": "^1.29",
    "phpstan/phpstan": "^2.1",
    "rector/rector": "^2.3"
  },
  "autoload": {
    "psr-0": {
      "Empathy": "src/",
      "Esuite": "t/"
    },
    "classmap": [
      "src/R.php"
    ]
  },
  "bin": [
    "bin/empathy"
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "format": "pint ./src ./t",
    "analyze": "phpstan --memory-limit=1G"
  }
}
